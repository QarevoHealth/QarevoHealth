# Backend API (Python/FastAPI on port 8000)
# NEXT_PUBLIC_ prefix makes it available in client components (browser).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Kept for server-only routes (app/api/*) that still read API_BASE_URL
API_BASE_URL=http://localhost:8000

# Optional: override demo IDs for Create Meeting (UUIDs)
# DEMO_PATIENT_ID=92f73e78-fffe-4c61-9796-73341be43c97
# DEMO_PROVIDER_ID=34879f64-3b5d-40c8-b22a-1dfd50dc5da9
