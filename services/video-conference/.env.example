# AWS Chime SDK Configuration
AWS_CHIME_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Join URL - Base URL for join links (your frontend app URL)
APP_JOIN_URL=https://your-app.com/join

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Application Configuration
APP_NAME=Video Conference Service
APP_VERSION=1.0.0
DEBUG=false

# Logging
LOG_LEVEL=INFO
